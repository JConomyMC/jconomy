# Auto detect text files and normalize line endings to LF
* text=auto

# Java files
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.properties text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.zip binary
*.class binary
